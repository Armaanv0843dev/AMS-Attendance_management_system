# .gitattributes — Normalize line endings across OS
# This ensures consistent LF in the repo (avoids CRLF/LF conflicts)

# Auto-detect text files and normalize to LF on commit
* text=auto eol=lf

# Explicitly declare source files as text
*.py        text eol=lf
*.jsx       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.example   text eol=lf

# Binary files — do not modify
*.pkl       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
